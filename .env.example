# MongoDB stores document metadata.
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=password123
MONGO_DATABASE=wrc_pipeline
LANDING_COLLECTION=landing_documents
PROCESSED_COLLECTION=processed_documents

# MinIO is S3-compatible object storage for the downloaded files.
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_SECURE=false
LANDING_BUCKET=landing-zone
PROCESSED_BUCKET=processed-zone

# Scraping behavior. These values are intentionally conservative.
PARTITION_SIZE_DAYS=30
CONCURRENT_REQUESTS=4
DOWNLOAD_DELAY=1.0
AUTOTHROTTLE_ENABLED=true
RETRY_TIMES=3
